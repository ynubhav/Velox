{
  "compilerOptions": {
    "target": "es2020",                                  
    "module": "nodenext",                                
    "rootDir": "./src",                                  
    "moduleResolution": "nodenext",                     
    "sourceMap": true,                                
    "outDir": "./dist",                                   
    "esModuleInterop": true,                             
    "forceConsistentCasingInFileNames": true,            
    "strict": true,                                      
    "skipLibCheck": true                                 
  }
}
